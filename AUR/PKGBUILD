# Maintainer: slax81 <s.milojkovic@gmail.com>
# based on ApprenticeVR by jimzrt <jimzrt1@gmail.com>
pkgname=agnosticvr-bin
pkgver=1.3.5
pkgrel=1
pkgdesc="A modern, cross-platform desktop application designed for managing and sideloading content onto Meta Quest devices"
arch=('x86_64' 'aarch64')
url="https://github.com/slax81/agnosticvr"
license=('GPL3')
depends=('fuse2')
optdepends=('libappindicator-gtk3: for tray icon support')
provides=('agnosticvr')
conflicts=('agnosticvr')
install=agnosticvr.install
options=('!debug' '!strip')
source=("agnosticvr.desktop"
        "agnosticvr.install"
        "https://raw.githubusercontent.com/slax81/agnosticvr/main/build/icon.png")
source_x86_64=("https://github.com/slax81/agnosticvr/releases/download/v${pkgver}/agnosticvr-${pkgver}-x86_64.AppImage")
source_aarch64=("https://github.com/slax81/agnosticvr/releases/download/v${pkgver}/agnosticvr-${pkgver}-arm64.AppImage")
sha256sums=('SKIP'
            'SKIP'
            'SKIP')
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

prepare() {
    if [ "$CARCH" = "x86_64" ]; then
        chmod +x "${srcdir}/agnosticvr-${pkgver}-x86_64.AppImage"
    elif [ "$CARCH" = "aarch64" ]; then
        chmod +x "${srcdir}/agnosticvr-${pkgver}-arm64.AppImage"
    fi
}

package() {
    # Determine the correct AppImage file based on architecture
    if [ "$CARCH" = "x86_64" ]; then
        _appimage="agnosticvr-${pkgver}-x86_64.AppImage"
    elif [ "$CARCH" = "aarch64" ]; then
        _appimage="agnosticvr-${pkgver}-arm64.AppImage"
    fi
  
    
    # Install the AppImage
    install -d "${pkgdir}/opt/agnosticvr"
    install -m755 "${srcdir}/${_appimage}" "${pkgdir}/opt/agnosticvr/agnosticvr.AppImage"
    
    
    # Create a wrapper script
    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/agnosticvr" << 'EOF'
#!/bin/bash
exec /opt/agnosticvr/agnosticvr.AppImage "$@"
EOF
    chmod +x "${pkgdir}/usr/bin/agnosticvr"
    
    # Install desktop file
    install -Dm644 "${srcdir}/agnosticvr.desktop" "${pkgdir}/usr/share/applications/agnosticvr.desktop"
    
    # Install icon
    install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/pixmaps/agnosticvr.png"
    install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/agnosticvr.png"
}
