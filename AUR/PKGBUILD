# Maintainer: slax81 <s.milojkovic@gmail.com>
# based on ApprenticeVR by jimzrt <jimzrt1@gmail.com>
pkgname=mythicquestvr-bin
pkgver=1.3.5
pkgrel=1
pkgdesc="A modern, cross-platform desktop application designed for managing and sideloading content onto Meta Quest devices"
arch=('x86_64' 'aarch64')
url="https://github.com/slax81/mythicquestvr"
license=('GPL3')
depends=('fuse2')
optdepends=('libappindicator-gtk3: for tray icon support')
provides=('mythicquestvr')
conflicts=('mythicquestvr')
install=mythicquestvr.install
options=('!debug' '!strip')
source=("mythicquestvr.desktop"
        "mythicquestvr.install"
        "https://raw.githubusercontent.com/slax81/mythicquestvr/main/build/icon.png")
source_x86_64=("https://github.com/slax81/mythicquestvr/releases/download/v${pkgver}/mythicquestvr-${pkgver}-x86_64.AppImage")
source_aarch64=("https://github.com/slax81/mythicquestvr/releases/download/v${pkgver}/mythicquestvr-${pkgver}-arm64.AppImage")
sha256sums=('SKIP'
            'SKIP'
            'SKIP')
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

prepare() {
    if [ "$CARCH" = "x86_64" ]; then
        chmod +x "${srcdir}/mythicquestvr-${pkgver}-x86_64.AppImage"
    elif [ "$CARCH" = "aarch64" ]; then
        chmod +x "${srcdir}/mythicquestvr-${pkgver}-arm64.AppImage"
    fi
}

package() {
    # Determine the correct AppImage file based on architecture
    if [ "$CARCH" = "x86_64" ]; then
        _appimage="mythicquestvr-${pkgver}-x86_64.AppImage"
    elif [ "$CARCH" = "aarch64" ]; then
        _appimage="mythicquestvr-${pkgver}-arm64.AppImage"
    fi
  
    
    # Install the AppImage
    install -d "${pkgdir}/opt/mythicquestvr"
    install -m755 "${srcdir}/${_appimage}" "${pkgdir}/opt/mythicquestvr/mythicquestvr.AppImage"
    
    
    # Create a wrapper script
    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/mythicquestvr" << 'EOF'
#!/bin/bash
exec /opt/mythicquestvr/mythicquestvr.AppImage "$@"
EOF
    chmod +x "${pkgdir}/usr/bin/mythicquestvr"
    
    # Install desktop file
    install -Dm644 "${srcdir}/mythicquestvr.desktop" "${pkgdir}/usr/share/applications/mythicquestvr.desktop"
    
    # Install icon
    install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/pixmaps/mythicquestvr.png"
    install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/mythicquestvr.png"
} 